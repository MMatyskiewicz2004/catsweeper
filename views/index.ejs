<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/styles.css" />
  </head>
  <body>
    <main class="container">
      <section class="startScreen" aria-label="Start screen">
        <div class="startScreen__titleWrap">
          <h1 class="startScreen__title">Cat Sweeper</h1>
          <img class="startScreen__cat" src="/assets/cat.webp" alt="Cat Sweeper cat" />
        </div>

        <div class="card startScreen__card">
          <div class="startScreen__leaderboardHead">
            <h2 class="card__title">Leaderboard</h2>
            <a class="link" href="/leaderboard">View all</a>
          </div>

          <div class="leaderboard leaderboard--start">
            <% if (!fastestWins || fastestWins.length === 0) { %>
              <div class="muted">No wins recorded yet.</div>
            <% } else { %>
              <% fastestWins.forEach((row, idx) => { %>
                <div class="leaderboard__row">
                  <div class="leaderboard__rank">#<%= idx + 1 %></div>
                  <div class="leaderboard__name"><%= row.playerName %></div>
                  <div class="leaderboard__time"><%= row.completionTimeMs ? Math.round(row.completionTimeMs / 1000) : '-' %>s</div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>

        <form class="startScreen__playForm" action="/game" method="get">
          <button type="submit" class="btn btn--primary startScreen__playBtn">Play</button>
        </form>
      </section>
    </main>
  </body>
</html>

